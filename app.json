{
  "expo": {
    "name": "FitCheck",
    "slug": "fitcheck",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo-placeholder-bk.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0e0e0e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fitcheck.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "FitCheck needs access to your photos to analyze garments.",
        "NSCameraUsageDescription": "FitCheck uses camera to photograph garments.",
        "NSLocationWhenInUseUsageDescription": "FitCheck needs location for weather-based outfit suggestions."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.fitcheck.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      "expo-image-picker",
      "expo-location",
      "expo-asset",
      "expo-font"
    ]
  }
}
